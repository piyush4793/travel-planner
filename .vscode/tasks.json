{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "typecheck",
      "type": "npm",
      "script": "tsc --noEmit",
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "silent", "revealProblems": "onProblem" }
    },
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "dev-server-bg",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "test",
      "type": "npm",
      "script": "test",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "test:coverage",
      "type": "npm",
      "script": "test:coverage",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "lint:unused",
      "type": "npm",
      "script": "lint:unused",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "validate (full)",
      "type": "npm",
      "script": "validate",
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "pre-commit check",
      "dependsOn": ["typecheck", "lint:unused"],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "check:coverage",
      "type": "shell",
      "command": "npm run check:coverage",
      "group": "test",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    }
  ]
}
