        "cost": "₹1,620"
      },
      {
        "from": "Saaremaa",
        "to": "Haapsalu",
        "method": "Coach from Kuressaare back across the Kuivastu–Virtsu ferry and onward to Haapsalu, about 4 hours",
        "cost": "₹1,350"
      }
