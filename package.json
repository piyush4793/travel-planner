{
  "name": "roamwise",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage && echo '\\n📊 HTML report: coverage/index.html'",
    "test:ui": "vitest --ui",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint:unused": "knip --reporter compact --tags='+public'",
    "check:coverage": "bash scripts/check-new-coverage.sh",
    "validate": "tsc --noEmit && vitest run && knip --reporter compact --tags='+public' && vite build",
    "prepare": "husky"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "knip": "^6.16.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.2",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  }
}
